@model IEnumerable<Habitly.Models.Habit>

@{
    ViewData["Title"] = "Seus Hábitos";
}

<h2 class="mb-3">Gestão de Hábitos</h2>

<form method="get" class="mb-3 d-flex">
    <input type="text" name="search" class="form-control me-2" placeholder="Buscar hábito..." />
    <button type="submit" class="btn btn-outline-primary">Buscar</button>
</form>

<a asp-action="Create" class="btn btn-primary mb-3">+ Novo Hábito</a>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Descrição</th>
            <th>Frequência</th>
            <th>Progresso</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Frequency</td>
                <td style="width: 150px;">
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar @(item.IsCompleted ? "bg-success" : "bg-info")"
                             role="progressbar"
                             style="width: @item.Progress%;"
                             aria-valuenow="@item.Progress"
                             aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                </td>
                <td>
                    @(item.IsCompleted ? "✅ Concluído" : "⏳ Em andamento")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                    @if (!item.IsCompleted)
                    {
                        <a asp-action="MarkAsDone" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            Concluir
                        </a>
                
                        <a asp-action="IncreaseProgress" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                            +10%
                        </a>
                    }
                    

                </td>
            </tr>
        }
    </tbody>
</table>
